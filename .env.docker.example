# Docker 环境变量
# 复制为 .env.docker 并填入实际值

# ── 服务器 ────────────────────────────────────────────────────────────────
PORT=3000

# ── MySQL（docker compose 时用 mysql 作为 host）──────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=assc_srm

# ── 飞书应用 ─────────────────────────────────────────────────────────────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFY_TOKEN=

# ── LLM（DeepSeek）────────────────────────────────────────────────────────
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=
LLM_BASE_URL=

# ── 服务地址 ─────────────────────────────────────────────────────────────
SERVER_URL=http://localhost:3000
WEB_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ── HRAS 壳子（可选）────────────────────────────────────────────────────
# HRAS_SHELL_URL=
# HRAS_SHELL_REGISTER_ENABLED=false
# HRAS_MODULE_KEY=hras-procurement
# HRAS_MODULE_NAME=采购项目进度管理
# HRAS_MODULE_FRONTEND_URL=http://localhost:3000
# HRAS_MODULE_BACKEND_URL=http://localhost:3000
